  "description": "Watches a Ticketmaster event page and sends a Telegram alert when resale inventory shows up.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "npx puppeteer browsers install chrome",

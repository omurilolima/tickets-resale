# TicketsResale — copy to .env and fill in (no spaces around =)

# Telegram: @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=
# Chat id(s): comma-separated for several recipients — each must /start your bot
# TELEGRAM_CHAT_ID=111111111,222222222
TELEGRAM_CHAT_ID=

# Optional: looser resale detection (noisier)
# TICKETSRESALE_LOOSE_RESALE=1
# TICKETSRESALE_RESALE_MARKERS=foo,bar

# Optional: system Chrome/Chromium if Puppeteer’s Chrome is missing
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
